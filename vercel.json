{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "api/health.py": {
      "maxDuration": 15,
      "memory": 512
    },
    "api/fabric_health.py": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/arcly_feedback.py": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/swarm.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}