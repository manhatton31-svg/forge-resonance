# =============================================================================
# ForgeResonance Environment Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
#
# Quick start: leave defaults — `python -m demo` works with zero API keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Backend: file | sqlite | neon | hybrid
# - file/sqlite: local only (good for dev and demo)
# - hybrid: local + Neon sync when DATABASE_URL is reachable
FORGE_STORAGE_BACKEND=hybrid

# -----------------------------------------------------------------------------
# Neon Postgres (optional — persistence + Fabric-scale memory)
# -----------------------------------------------------------------------------
# Provisioned via Neon MCP on project: forge-resonance
# Leave empty for demo; set for production agent persistence.
#
# Tables: agents, working_memory, episodic_memory, resonance_events,
#         reputation_ledger
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Neon project metadata (for MCP tooling — not required at runtime)
NEON_PROJECT_ID=late-glade-09092928
NEON_BRANCH_ID=br-jolly-mountain-adw7q2vw
NEON_DATABASE=neondb

# -----------------------------------------------------------------------------
# xAI / Grok (optional — generation)
# -----------------------------------------------------------------------------
# Empty XAI_API_KEY → template fallback (demo default).
# Set key to enable Grok-powered ResonancePayload generation.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-mini
GROK_TEMPERATURE=0.55
GROK_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Arcly AI Closer (conversion handoff)
# -----------------------------------------------------------------------------
# ForgeResonance hands qualified resonances to Arcly for close tracking.
#
# ARCLY_MODE:
#   auto     — live when ARCLY_API_KEY + non-local ARCLY_API_URL (default)
#   dry_run  — simulate handoff, log reputation context (demo default)
#   live     — force production POST with retries
#
# Without ARCLY_API_KEY or with localhost URL → dry_run automatically.
ARCLY_API_URL=http://localhost:8000
ARCLY_API_KEY=
ARCLY_HANDOFF_TIMEOUT=30
ARCLY_HANDOFF_MAX_RETRIES=2
ARCLY_HANDOFF_RETRY_DELAY=1.0
ARCLY_MODE=auto

# When true, Arcly can POST outcomes to /api/arcly_feedback to update scores
ARCLY_FEEDBACK_ENABLED=true

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=forge-resonance
# Demo CLI sets WARNING automatically; use INFO for development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Cloudflare Edge Reputation (M4 — KV replication layer)
# -----------------------------------------------------------------------------
# Neon/SQLite remain source of truth. KV is a fast edge cache for scores and
# visibility multipliers, written after each outcome when enabled.
#
# EDGE_REPUTATION_ENABLED=false  → no KV sync (default, backward compatible)
# EDGE_REPUTATION_ENABLED=true   → requires token, account, and namespace below
EDGE_REPUTATION_ENABLED=false

# Read preference for ranking/selection when edge is enabled:
#   edge_first  — prefer KV, blend when both local and edge exist (default)
#   local_first — prefer local when warm, else KV; blend when both exist
#   local_only  — ignore KV for reads (sync still writes if enabled)
EDGE_READ_PREFERENCE=edge_first

# Cloudflare API credentials (Workers KV REST API)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE=

# Legacy aliases (still supported)
CF_ACCOUNT_ID=
CF_REPUTATION_KV_NAMESPACE=
CF_API_TOKEN=

# KV key prefix for agent records (default: reputation:)
CLOUDFLARE_KV_KEY_PREFIX=reputation:
CLOUDFLARE_KV_TIMEOUT=10

# -----------------------------------------------------------------------------
# Firecrawl (optional — intent enrichment from URLs in text)
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=
FIRECRAWL_ENABLED=false

# -----------------------------------------------------------------------------
# Intent harvesting thresholds
# -----------------------------------------------------------------------------
# Signals below INTENT_RESONANCE_THRESHOLD are skipped (no resonance cycle).
INTENT_RESONANCE_THRESHOLD=0.35
INTENT_SIMILARITY_THRESHOLD=0.55
INTENT_MULTI_TURN_LIMIT=5

# -----------------------------------------------------------------------------
# Agent runtime
# -----------------------------------------------------------------------------
AGENT_LOOP_INTERVAL=5.0
WORKING_MEMORY_TTL=3600
EPISODIC_MEMORY_LIMIT=1000

# -----------------------------------------------------------------------------
# Swarm execution (Fabric multi-agent coordination)
# -----------------------------------------------------------------------------
# Per-agent resonance cycle timeout in seconds (0 = no timeout)
SWARM_AGENT_TIMEOUT=120

# Max agents to execute in parallel during BROADCAST_TOP_N
SWARM_MAX_PARALLEL=3

# Consensus strategy for broadcast mode:
#   majority         — simple vote count across agent outcomes
#   quality_weighted — weight votes by quality × routing score
SWARM_CONSENSUS_STRATEGY=quality_weighted

# Serverless caps (applied automatically when VERCEL=1)
SWARM_SERVERLESS_TIMEOUT=25
SWARM_SERVERLESS_MAX_PARALLEL=2

# -----------------------------------------------------------------------------
# Vercel deployment (set in Vercel dashboard — do not commit secrets)
# -----------------------------------------------------------------------------
# VERCEL=1 is injected automatically on Vercel; do not set locally unless testing.
# VERCEL_FUNCTION_MAX_DURATION=60
# FORGE_API_KEY=           # optional Bearer auth for POST /api/swarm
# FORGE_STORAGE_BACKEND=neon
#
# Deploy:
#   vercel link && vercel --prod
# See docs/deployment.md for full guide.