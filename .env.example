# ForgeResonance Environment Configuration
# Copy to .env and fill in values

# Storage backend: file | sqlite | neon | hybrid
FORGE_STORAGE_BACKEND=hybrid

# Neon Postgres (provisioned via Neon MCP — project: forge-resonance)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
NEON_PROJECT_ID=late-glade-09092928
NEON_BRANCH_ID=br-jolly-mountain-adw7q2vw
NEON_DATABASE=neondb

# xAI / Grok
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-mini
GROK_TEMPERATURE=0.55
GROK_MAX_TOKENS=1024

# Arcly Integration
ARCLY_API_URL=http://localhost:8000
ARCLY_API_KEY=
ARCLY_HANDOFF_TIMEOUT=30

# Observability
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=forge-resonance
LOG_LEVEL=INFO

# Cloudflare (future edge deployment)
CF_ACCOUNT_ID=
CF_REPUTATION_KV_NAMESPACE=

# Firecrawl (future intent enrichment)
FIRECRAWL_API_KEY=
FIRECRAWL_ENABLED=false

# Intent harvesting thresholds
INTENT_RESONANCE_THRESHOLD=0.35
INTENT_SIMILARITY_THRESHOLD=0.55
INTENT_MULTI_TURN_LIMIT=5

# Agent runtime
AGENT_LOOP_INTERVAL=5.0
WORKING_MEMORY_TTL=3600
EPISODIC_MEMORY_LIMIT=1000